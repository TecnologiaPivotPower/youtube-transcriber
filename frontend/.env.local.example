# ─── Supabase ────────────────────────────────────────────────────────────────
# URL del proyecto (visible en Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Anon key — pública, se puede exponer al browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — PRIVADA, solo usar en API routes server-side, nunca en el browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Worker (Railway) ─────────────────────────────────────────────────────────
# URL del worker de FastAPI en Railway (disponible después de hacer deploy)
WORKER_URL=https://xxxx.up.railway.app

# Token secreto compartido entre frontend y worker para auth interna
# Generar con: openssl rand -hex 32
WORKER_SECRET=un_token_secreto_para_auth_interna
